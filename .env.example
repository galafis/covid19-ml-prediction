# COVID-19 ML Prediction - Environment Configuration

# Data Sources
BRASIL_IO_API_URL=https://brasil.io/api/dataset/covid19/caso_full/data/
JOHNS_HOPKINS_BASE_URL=https://raw.githubusercontent.com/CSSEGISandData/COVID-19/master/
IBGE_API_URL=https://servicodados.ibge.gov.br/api/v3/

# Pipeline Configuration
DATA_DIR=./data
MODEL_DIR=./models
LOG_LEVEL=INFO
BATCH_SIZE=1000

# Model Parameters
FORECAST_HORIZON=14
TRAIN_TEST_SPLIT=0.8
RANDOM_STATE=42

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# MLflow
MLFLOW_TRACKING_URI=./mlruns
